# پورت اجرای سرور
PORT=4000

# آدرس اتصال به دیتابیس PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rasadlink

# آدرس پایه‌ای که فایل‌های آپلودشده (اسکرین‌شات‌ها) از آن سرو می‌شوند
PUBLIC_BASE_URL=http://localhost:4000

# مبدا(های) مجاز برای CORS، جدا شده با کاما (مثلاً آدرس فرانت‌اند)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# زمان‌بندی بررسی خودکار لینک‌ها (فرمت cron) — هر ۱۲ دقیقه
CHECK_CRON=*/12 * * * *

# حداکثر زمان انتظار برای بارگذاری هر صفحه (میلی‌ثانیه)
SCRAPE_TIMEOUT_MS=30000

# حداقل تعداد کاراکتر محتوای «جدید و معنادار» برای اینکه یک تغییر واقعی در نظر گرفته شود
MIN_ADDED_CHARS=40

# تعداد لینک‌هایی که هم‌زمان بررسی می‌شوند (برای جلوگیری از فشار زیاد به CPU/RAM)
CHECK_CONCURRENCY=3

# ------------------------------------------------------------------
# تنظیمات مخصوص هاست رایگان (اختیاری — برای اجرای محلی/VPS نیازی نیست)
# ------------------------------------------------------------------

# درایور ذخیره‌سازی اسکرین‌شات: local (دیسک سرور) یا supabase (توصیه‌شده برای هاست رایگان)
STORAGE_DRIVER=local

# فقط وقتی STORAGE_DRIVER=supabase لازم است (از Project Settings > API در Supabase بگیرید)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=screenshots

# روی هاست رایگانی که پروسه می‌خوابد (مثل Render Free)، زمان‌بند داخلی را خاموش کنید
# و به‌جایش از یک cron خارجی رایگان (مثل cron-job.org) برای فراخوانی /api/cron/run-check استفاده کنید
ENABLE_INTERNAL_SCHEDULER=true

# یک رشته‌ی تصادفی و طولانی برای محافظت از /api/cron/run-check در برابر فراخوانی‌های ناخواسته
CRON_SECRET=
